<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.taoxier.smartdochub.document.mapper.TopicMapper">

    <!-- 通用查询映射结果 -->
    <resultMap id="BaseResultMap" type="com.taoxier.smartdochub.document.model.entity.Topic">
        <id column="id" property="id" />
        <result column="document_id" property="documentId" />
        <result column="topic_type" property="topicType" />
        <result column="topic_value" property="topicValue" />
        <result column="confidence" property="confidence" />
        <result column="weight" property="weight" />
        <result column="create_time" property="createTime" />
    </resultMap>

    <!-- 通用查询结果列 -->
    <sql id="Base_Column_List">
        id, document_id, topic_type, topic_value, confidence, weight, create_time
    </sql>

</mapper>
